def show_peers(asn_num, pdb_net_id=None):
    """Lista todos os peers de um ASN nos IXs (PeeringDB)."""
    print(f"\n{'─'*64}")
    print(f"  AS{asn_num} — Peers em IXs (PeeringDB)")
    print(f"{'─'*64}")

    if not pdb_net_id:
        print("  ASN não cadastrado no PeeringDB.")
        return

    my_ixlans = _pdb_get("/netixlan", {"net_id": pdb_net_id, "fields": "ixlan_id"})
    if not my_ixlans:
        print("  Nenhum IX encontrado.")
        return

    ixlan_ids = list({n["ixlan_id"] for n in my_ixlans})
    seen, peer_asns = set(), []
    for ixlan_id in ixlan_ids[:5]:
        for p in _pdb_get("/netixlan", {"ixlan_id": ixlan_id, "fields": "asn", "limit": 200}):
            a = p.get("asn")
            if a and a != int(asn_num) and a not in seen:
                seen.add(a)
                peer_asns.append(a)

    if not peer_asns:
        print("  Nenhum peer encontrado.")
        return

    sample  = peer_asns[:50]
    net_map = _pdb_enrich_asns(sample)

    rows = [[a, net_map.get(a, {}).get("name", "N/A")] for a in sample]
    print(tabulate(rows, headers=["ASN Peer", "Nome"],
                   tablefmt="fancy_grid", numalign="left", stralign="left"))
    if len(peer_asns) > 50:
        print(f"  ... e mais {len(peer_asns) - 50} peer(s).")


def show_check_peering(asn1_input, asn2_input):
    """
    Verifica se dois ASNs peeream diretamente em algum IX (PeeringDB).
    Uso: bgpnr --peers ASN1 ASN2
    """
    a1 = _asn_num(asn1_input)
    a2 = _asn_num(asn2_input)

    print(f"\n{'═'*64}")
    print(f"  Verificando peering direto: AS{a1}  ×  AS{a2}")
    print(f"{'═'*64}")

    p1 = _pdb_net(a1)
    p2 = _pdb_net(a2)

    if not p1:
        print(f"  [!] AS{a1} não encontrado no PeeringDB.")
        return
    if not p2:
        print(f"  [!] AS{a2} não encontrado no PeeringDB.")
        return

    # IXlans de cada ASN
    ix1_list = _pdb_get("/netixlan", {"net_id": p1["id"]})
    ix2_list = _pdb_get("/netixlan", {"net_id": p2["id"]})

    ixlan_ids_1 = {n["ixlan_id"] for n in ix1_list}
    ixlan_ids_2 = {n["ixlan_id"] for n in ix2_list}
    common_ixlan_ids = ixlan_ids_1 & ixlan_ids_2

    if not common_ixlan_ids:
        print(f"\n  ❌  AS{a1} e AS{a2} NÃO estão presentes em nenhum IX em comum.")
        print(f"      AS{a1}: {len(ixlan_ids_1)} IX(s)  |  AS{a2}: {len(ixlan_ids_2)} IX(s)")
        return

    # Busca nomes dos IXs em comum
    ixlan_map = {
        il["id"]: il
        for il in _pdb_get("/ixlan", {"id__in": ",".join(str(i) for i in common_ixlan_ids)})
    }
    ix_ids = list({str(il["ix_id"]) for il in ixlan_map.values() if il.get("ix_id")})
    ix_map = {ix["id"]: ix for ix in _pdb_get("/ix", {"id__in": ",".join(ix_ids)})} if ix_ids else {}

    # Indexa sessões por ixlan_id para buscar IPs
    sess1 = {n["ixlan_id"]: n for n in ix1_list}
    sess2 = {n["ixlan_id"]: n for n in ix2_list}

    print(f"\n  ✅  AS{a1} e AS{a2} estão presentes em {len(common_ixlan_ids)} IX(s) em comum:\n")

    rows = []
    for ixlan_id in sorted(common_ixlan_ids):
        ixlan = ixlan_map.get(ixlan_id, {})
        ix    = ix_map.get(ixlan.get("ix_id"), {})
        s1    = sess1.get(ixlan_id, {})
        s2    = sess2.get(ixlan_id, {})
        rows.append([
            ix.get("name") or ixlan.get("name") or "N/A",
            ix.get("country", "N/A"),
            s1.get("ipaddr4") or "N/A",
            s2.get("ipaddr4") or "N/A",
            s1.get("ipaddr6") or "N/A",
            s2.get("ipaddr6") or "N/A",
            _speed_str(s1.get("speed", 0)),
            _speed_str(s2.get("speed", 0)),
        ])

    print(tabulate(rows,
                   headers=["IX", "País",
                             f"IPv4 AS{a1}", f"IPv4 AS{a2}",
                             f"IPv6 AS{a1}", f"IPv6 AS{a2}",
                             f"Vel. AS{a1}", f"Vel. AS{a2}"],
                   tablefmt="fancy_grid", numalign="left", stralign="left"))


def search_by_name(query):
    print(f"\n  Buscando ASNs para: '{query}'")

    seen = {}

    # PeeringDB
    for net in _pdb_get("/net", {"name__contains": query, "limit": 50}):
        a = net.get("asn")
        if a:
            seen[a] = [a, net.get("name","N/A"), "PeeringDB"]

    # RIPE Stat searchcomplete
    try:
        r = SESSION.get(
            "https://stat.ripe.net/data/searchcomplete/data.json",
            params={"resource": query, "limit": 20, "sourceapp": "bgpnr"},
            timeout=20,
        )
        r.raise_for_status()
        for cat in r.json().get("data", {}).get("categories", []):
            if cat.get("category") == "ASNs":
                for item in cat.get("suggestions", []):
                    v = item.get("value", "")
                    if v.upper().startswith("AS"):
                        try:
                            a   = int(v.split()[0].lstrip("AS").rstrip(","))
                            lbl = item.get("label") or " ".join(v.split()[1:])
                            if a not in seen:
                                seen[a] = [a, lbl, "RIPE Stat"]
                        except Exception:
                            pass
    except Exception:
        pass

    if seen:
        print(tabulate(list(seen.values()), headers=["ASN", "Nome", "Fonte"],
                       tablefmt="fancy_grid", numalign="left", stralign="left"))
    else:
        print("  Nenhum ASN encontrado.")


# ─── comparação de dois ASNs ──────────────────────────────────────────────────

def show_compare(asn1_input, asn2_input):
    a1 = _asn_num(asn1_input)
    a2 = _asn_num(asn2_input)

    print(f"\n{'═'*64}")
    print(f"  Comparação: AS{a1}  ×  AS{a2}")
    print(f"{'═'*64}")

    # ── Detalhes lado a lado ──────────────────────────────────────
    r1  = _ripe_asn_details(a1);  p1  = _pdb_net(a1)
    r2  = _ripe_asn_details(a2);  p2  = _pdb_net(a2)

    def _val(d_ripe, d_pdb, key_ripe, key_pdb=None):
        v = d_ripe.get(key_ripe) or (d_pdb.get(key_pdb or key_ripe) if d_pdb else None)
        return v or "N/A"

    rows = [
        ["Campo",            f"AS{a1}",                          f"AS{a2}"],
        ["Nome",             r1["holder"] or p1.get("name","N/A"), r2["holder"] or p2.get("name","N/A")],
        ["País",             r1["country"],                        r2["country"]],
        ["RIR",              r1["rir"],                            r2["rir"]],
        ["Alocado em",       r1["alloc_time"],                     r2["alloc_time"]],
        ["Website",          p1.get("website") or "N/A",           p2.get("website") or "N/A"],
        ["IRR AS-SET",       p1.get("irr_as_set") or "N/A",        p2.get("irr_as_set") or "N/A"],
        ["Tipo de rede",     p1.get("info_type") or "N/A",         p2.get("info_type") or "N/A"],
        ["Política de peer", p1.get("policy_general") or "N/A",    p2.get("policy_general") or "N/A"],
        ["IPv6",             "✅" if p1.get("info_ipv6") else "❌", "✅" if p2.get("info_ipv6") else "❌"],
        ["Fonte PeeringDB",  "✅" if p1 else "❌",                  "✅" if p2 else "❌"],
    ]
    print(tabulate(rows, headers="firstrow",
                   tablefmt="fancy_grid", numalign="left", stralign="left"))

    # ── Prefixos / RPKI ───────────────────────────────────────────
    print(f"\n{'─'*64}")
    print(f"  Prefixos")
    print(f"{'─'*64}")

    pref1 = _ripe_prefixes(a1)
    pref2 = _ripe_prefixes(a2)

    def _pfx_summary(pfxs):
        v4 = [p for p in pfxs if not p["is_v6"]]
        v6 = [p for p in pfxs if p["is_v6"]]
        ok = sum(1 for p in pfxs if p["rpki"] == "valid")
        return f"IPv4: {len(v4)}  IPv6: {len(v6)}  RPKI✅: {ok}"

    rows = [
        ["Campo",    f"AS{a1}",          f"AS{a2}"],
        ["Prefixos", _pfx_summary(pref1), _pfx_summary(pref2)],
    ]
    print(tabulate(rows, headers="firstrow",
                   tablefmt="fancy_grid", numalign="left", stralign="left"))

    # ── Upstreams ─────────────────────────────────────────────────
    print(f"\n{'─'*64}")
    print(f"  Upstreams")
    print(f"{'─'*64}")

    up1, _ = _ripe_neighbours(a1)
    up2, _ = _ripe_neighbours(a2)
    set1   = {u["asn"] for u in up1}
    set2   = {u["asn"] for u in up2}
    common_up = sorted(set1 & set2)

    rows = [["Campo", f"AS{a1}", f"AS{a2}"]]
    rows.append(["Total upstreams", len(up1), len(up2)])

    common_names = {}
    if common_up:
        nm = _pdb_enrich_asns(common_up)
        common_names = {a: nm.get(a, {}).get("name", "N/A") for a in common_up}

    rows.append([
        "Upstreams em comum",
        len(common_up),
        ", ".join(f"AS{a}" for a in common_up[:10]) or "Nenhum",
    ])
    print(tabulate(rows, headers="firstrow",
                   tablefmt="fancy_grid", numalign="left", stralign="left"))

    if common_up:
        up_rows = [[a, common_names.get(a, "N/A")] for a in common_up]
        print(tabulate(up_rows, headers=["ASN Upstream comum", "Nome"],
                       tablefmt="fancy_grid", numalign="left", stralign="left"))

    # ── IXs em comum ─────────────────────────────────────────────
    print(f"\n{'─'*64}")
    print(f"  Internet Exchanges em comum (PeeringDB)")
    print(f"{'─'*64}")

    pid1 = p1.get("id") if p1 else None
    pid2 = p2.get("id") if p2 else None

    ix1 = _pdb_ixs(pid1)
    ix2 = _pdb_ixs(pid2)

    # Identifica IXs em comum pelo nome do IX
    names1 = {ix["name"] for ix in ix1 if ix["name"] != "N/A"}
    names2 = {ix["name"] for ix in ix2 if ix["name"] != "N/A"}
    common_ix_names = names1 & names2

    if common_ix_names:
        # Monta tabela com dados de ambos os ASNs no IX
        ix1_map = {ix["name"]: ix for ix in ix1}
        ix2_map = {ix["name"]: ix for ix in ix2}
        rows = []
        for name in sorted(common_ix_names):
            i1 = ix1_map.get(name, {})
            i2 = ix2_map.get(name, {})
            rows.append([
                name,
                i1.get("ipv4", "N/A"),
                i2.get("ipv4", "N/A"),
                i1.get("ipv6", "N/A"),
                i2.get("ipv6", "N/A"),
                _speed_str(i1.get("speed", 0)),
                _speed_str(i2.get("speed", 0)),
            ])
        print(tabulate(rows,
                       headers=["IX", f"IPv4 AS{a1}", f"IPv4 AS{a2}",
                                 f"IPv6 AS{a1}", f"IPv6 AS{a2}",
                                 f"Vel. AS{a1}", f"Vel. AS{a2}"],
                       tablefmt="fancy_grid", numalign="left", stralign="left"))
        print(f"  {len(common_ix_names)} IX(s) em comum — peering direto possível.")
    else:
        print(f"  AS{a1} e AS{a2} não compartilham nenhum IX no PeeringDB.")
        print(f"  (AS{a1}: {len(ix1)} IX(s)  |  AS{a2}: {len(ix2)} IX(s))")


# ─── lookup completo ──────────────────────────────────────────────────────────

def lookup_asn(asn_input, sections=None):
    asn_num = _asn_num(asn_input)
    if not asn_num.isdigit():
        print(f"  [!] ASN inválido: '{asn_input}'")
        return

    all_s = sections is None

    _, pdb = show_asn_details(asn_num)
    pdb_id = pdb.get("id") if pdb else None

    if all_s or "prefixes"    in sections: show_prefixes(asn_num)
    if all_s or "upstreams"   in sections: show_upstreams(asn_num)
    if all_s or "downstreams" in sections: show_downstreams(asn_num)
    if all_s or "ixs"         in sections: show_ixs(asn_num, pdb_id)
    if all_s or "facilities"  in sections: show_facilities(pdb_id)
    if all_s or "peers"       in sections: show_peers(asn_num, pdb_id)


# ─── CLI ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="bgpnr",
        description="bgpnr — BGP Network Research Tool (RIPE Stat + PeeringDB)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Exemplos:
  bgpnr 15169              # Consulta completa do AS15169 (Google)
  bgpnr AS1916             # Aceita formato AS+número
  bgpnr -s Claro           # Busca ASNs pelo nome
  bgpnr -p 15169           # Apenas prefixos + status RPKI + BGP + IRR
  bgpnr -u 15169           # Apenas upstreams (trânsito)
  bgpnr -d 15169           # Apenas downstreams (clientes)
  bgpnr -i 15169           # Apenas Internet Exchanges
  bgpnr -f 15169           # Apenas facilities/POPs (PeeringDB)
  bgpnr --peers 15169      # Peers em IXs comuns (PeeringDB)
  bgpnr --compare 262979 61696  # Compara dois ASNs lado a lado
        """,
    )
    parser.add_argument("asn",              nargs="?",
                        help="ASN para consulta completa (ex: 15169 ou AS15169)")
    parser.add_argument("-s", "--search",    metavar="NOME",
                        help="Busca ASNs por nome")
    parser.add_argument("-p", "--prefixes",  metavar="ASN",
                        help="Apenas prefixos IPv4/IPv6 com RPKI, BGP e IRR")
    parser.add_argument("-u", "--upstreams", metavar="ASN",
                        help="Apenas upstreams (trânsito)")
    parser.add_argument("-d", "--downstreams", metavar="ASN",
                        help="Apenas downstreams (clientes)")
    parser.add_argument("-i", "--ixs",       metavar="ASN",
                        help="Apenas Internet Exchanges (PeeringDB)")
    parser.add_argument("-f", "--facilities", metavar="ASN",
                        help="Apenas facilities/POPs (PeeringDB)")
    parser.add_argument("--peers",           nargs="+", metavar="ASN",
                        help="1 ASN: lista todos os peers nos IXs  |  2 ASNs: verifica peering direto entre eles")
    parser.add_argument("--compare",         nargs=2, metavar=("ASN1", "ASN2"),
                        help="Compara dois ASNs lado a lado (detalhes, prefixos, upstreams, IXs comuns)")
    args = parser.parse_args()

    if args.compare:
        show_compare(args.compare[0], args.compare[1])
    elif args.search:
        search_by_name(args.search)
    elif args.prefixes:
        show_prefixes(_asn_num(args.prefixes))
    elif args.upstreams:
        show_upstreams(_asn_num(args.upstreams))
    elif args.downstreams:
        show_downstreams(_asn_num(args.downstreams))
    elif args.ixs:
        n = _asn_num(args.ixs)
        show_ixs(n, _pdb_net(n).get("id"))
    elif args.facilities:
        n = _asn_num(args.facilities)
        show_facilities(_pdb_net(n).get("id"))
    elif args.peers:
        if len(args.peers) == 2:
            show_check_peering(args.peers[0], args.peers[1])
        else:
            n = _asn_num(args.peers[0])
            show_peers(n, _pdb_net(n).get("id"))
    elif args.asn:
        lookup_asn(args.asn)
    else:
        entrada = input("Insira um ASN (ex.: 15169) ou nome para pesquisar: ").strip()
        if not entrada:
            parser.print_help()
            sys.exit(0)
        if entrada.isdigit() or entrada.upper().startswith("AS"):
            lookup_asn(entrada)
        else:
            search_by_name(entrada)


if __name__ == "__main__":
    main()

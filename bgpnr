import requests
import sys
import argparse
from tabulate import tabulate

RIPESTAT_BASE  = "https://stat.ripe.net/data"
PEERINGDB_BASE = "https://www.peeringdb.com/api"

SESSION = requests.Session()
SESSION.headers.update({
    "User-Agent": "bgpnr/2.1 (github.com/efilho89/BGP-CONSULTA)",
    "Accept":     "application/json",
})


# ─── API helpers ──────────────────────────────────────────────────────────────

def _ripe_get(endpoint, params=None):
    url = f"{RIPESTAT_BASE}/{endpoint}/data.json"
    p = dict(params or {})
    p.setdefault("sourceapp", "bgpnr")
    try:
        r = SESSION.get(url, params=p, timeout=20)
        r.raise_for_status()
        return r.json().get("data") or {}
    except requests.RequestException as e:
        print(f"  [!] Erro RIPE Stat ({endpoint}): {e}")
        return {}


def _pdb_get(path, params=None):
    try:
        r = SESSION.get(f"{PEERINGDB_BASE}{path}", params=params, timeout=20)
        r.raise_for_status()
        return r.json().get("data") or []
    except requests.RequestException as e:
        print(f"  [!] Erro PeeringDB ({path}): {e}")
        return []


# ─── utilitários ──────────────────────────────────────────────────────────────

def _asn_num(asn_input):
    return str(asn_input).strip().upper().lstrip("AS")


def _fmt_date(s):
    if not s or s == "N/A":
        return "N/A"
    try:
        # "20131210" → "10/12/2013"
        s = str(s).split("T")[0].replace("-", "")
        if len(s) == 8 and s.isdigit():
            return f"{s[6:8]}/{s[4:6]}/{s[0:4]}"
        return s
    except Exception:
        return str(s)


def _speed_str(mbps):
    if not mbps:
        return "N/A"
    return f"{mbps / 1000:.1f} Gbps" if mbps >= 1000 else f"{mbps} Mbps"


# ─── PeeringDB — lookups em lote (batch) ──────────────────────────────────────

def _pdb_net(asn_num):
    nets = _pdb_get("/net", {"asn": asn_num})
    return nets[0] if nets else {}


def _pdb_ixs(pdb_net_id):
    """
    Retorna lista de IXs com nome, país, cidade, IPs, velocidade, RS Peer e BFD.
    Usa 3 chamadas em batch para evitar o problema com depth=2.
    """
    if not pdb_net_id:
        return []

    # 1) netixlan → lista de sessões do ASN nos IXs
    netixlans = _pdb_get("/netixlan", {"net_id": pdb_net_id})
    if not netixlans:
        return []

    # 2) ixlan → nome do LAN segment + ix_id
    ixlan_ids = list({str(n["ixlan_id"]) for n in netixlans})
    ixlan_map = {
        il["id"]: il
        for il in _pdb_get("/ixlan", {"id__in": ",".join(ixlan_ids)})
    }

    # 3) ix → nome do IX, país, cidade
    ix_ids = list({str(il["ix_id"]) for il in ixlan_map.values() if il.get("ix_id")})
    ix_map = {}
    if ix_ids:
        ix_map = {
            ix["id"]: ix
            for ix in _pdb_get("/ix", {"id__in": ",".join(ix_ids)})
        }

    result = []
    for n in netixlans:
        ixlan = ixlan_map.get(n.get("ixlan_id"), {})
        ix    = ix_map.get(ixlan.get("ix_id"), {})
        result.append({
            "name":    ix.get("name")    or ixlan.get("name") or "N/A",
            "country": ix.get("country") or "N/A",
            "city":    ix.get("city")    or "N/A",
            "ipv4":    n.get("ipaddr4")  or "N/A",
            "ipv6":    n.get("ipaddr6")  or "N/A",
            "speed":   n.get("speed", 0),
            "rs_peer": n.get("is_rs_peer", False),
            "bfd":     n.get("bfd_support", False),
        })
    return result


def _pdb_facilities(pdb_net_id):
    """
    Retorna lista de facilities com nome, país, cidade, endereço.
    Usa 2 chamadas em batch.
    """
    if not pdb_net_id:
        return []
    netfacs = _pdb_get("/netfac", {"net_id": pdb_net_id})
    if not netfacs:
        return []
    fac_ids = list({str(nf["fac_id"]) for nf in netfacs if nf.get("fac_id")})
    fac_map = {
        f["id"]: f
        for f in _pdb_get("/fac", {"id__in": ",".join(fac_ids)})
    }
    return [fac_map[nf["fac_id"]] for nf in netfacs if nf.get("fac_id") in fac_map]


def _pdb_enrich_asns(asn_list):
    """Retorna dict {asn: {name, ...}} para uma lista de ASNs (batch)."""
    if not asn_list:
        return {}
    sample = [str(a) for a in asn_list[:100]]
    nets = _pdb_get("/net", {"asn__in": ",".join(sample), "fields": "asn,name", "limit": 100})
    return {n["asn"]: n for n in nets}


# ─── RIPE Stat — lookups ───────────────────────────────────────────────────────

def _rdap_alloc_date(asn_num):
    """
    Data de alocação via RDAP (rdap.org → redireciona para o RIR correto).
    Funciona para LACNIC, RIPE, ARIN, APNIC e AFRINIC.
    Usa Accept: application/rdap+json (obrigatório pelo protocolo RDAP).
    """
    try:
        r = SESSION.get(
            f"https://rdap.org/autnum/{asn_num}",
            timeout=15,
            allow_redirects=True,
            headers={"Accept": "application/rdap+json"},
        )
        r.raise_for_status()
        for event in r.json().get("events", []):
            if event.get("eventAction") == "registration":
                return _fmt_date(event.get("eventDate", ""))
    except Exception:
        pass
    return "N/A"


def _ripe_asn_details(asn_num):
    """Combina as-overview + rir + rir-stats-country + RDAP para montar os detalhes do ASN."""
    overview     = _ripe_get("as-overview",      {"resource": f"AS{asn_num}"})
    rir_data     = _ripe_get("rir",              {"resource": f"AS{asn_num}"})
    country_data = _ripe_get("rir-stats-country", {"resource": f"AS{asn_num}"})

    # País via rir-stats-country → located_resources[0].location
    located = country_data.get("located_resources", [])
    country = located[0].get("location", "N/A").upper() if located else "N/A"

    # RIR via rir → rirs[0].rir
    rirs     = rir_data.get("rirs", [])
    rir_name = rirs[0].get("rir", "N/A").upper() if rirs else "N/A"

    # Data de alocação via RDAP (funciona para todos os RIRs)
    alloc_time = _rdap_alloc_date(asn_num)

    return {
        "holder":     overview.get("holder", "N/A"),
        "announced":  overview.get("announced", False),
        "country":    country,
        "rir":        rir_name,
        "alloc_time": alloc_time,
    }


def _ripe_prefixes(asn_num):
    """
    Prefixos via announced-prefixes + rpki-validation por prefixo.
    RPKI: valid / invalid / unknown.
    Limita a validação RPKI a 40 prefixos para não sobrecarregar a API.
    """
    ann = _ripe_get("announced-prefixes", {"resource": f"AS{asn_num}"})
    prefixes = [p["prefix"] for p in ann.get("prefixes", []) if p.get("prefix")]

    result = []
    for i, prefix in enumerate(prefixes):
        rpki = "unknown"
        if i < 40:
            vdata = _ripe_get("rpki-validation", {
                "resource": f"AS{asn_num}",
                "prefix":   prefix,
            })
            rpki = vdata.get("status", "unknown")   # "valid" / "invalid" / "unknown"
        result.append({
            "prefix":  prefix,
            "rpki":    rpki,
            "is_v6":   ":" in prefix,
        })
    return result


def _ripe_neighbours(asn_num):
    """Upstreams (type=left) e downstreams (type=right) via asn-neighbours."""
    data       = _ripe_get("asn-neighbours", {"resource": f"AS{asn_num}"})
    neighbours = data.get("neighbours", [])
    upstreams   = [n for n in neighbours if n.get("type") == "left"]
    downstreams = [n for n in neighbours if n.get("type") == "right"]
    return upstreams, downstreams


# ─── funções de exibição ──────────────────────────────────────────────────────

def show_asn_details(asn_num):
    print(f"\n{'═'*64}")
    print(f"  AS{asn_num} — Detalhes")
    print(f"{'═'*64}")

    ripe = _ripe_asn_details(asn_num)
    pdb  = _pdb_net(asn_num)

    rows = [
        ["AS Number",        f"AS{asn_num}"],
        ["Nome",             ripe["holder"]   or pdb.get("name", "N/A")],
        ["País",             ripe["country"]],
        ["RIR",              ripe["rir"]],
        ["Alocado em",       ripe["alloc_time"]],
        ["Anunciado",        "✅" if ripe["announced"] else "❌"],
        ["Website",          pdb.get("website")  or "N/A"],
        ["Contatos",         ", ".join(pdb.get("email_contacts") or []) or "N/A"],
        ["IRR AS-SET",       pdb.get("irr_as_set")    or "N/A"],
        ["Tipo de rede",     pdb.get("info_type")     or "N/A"],
        ["Unicast IPv4",     "✅" if pdb.get("info_unicast")   else ("❌" if pdb else "N/A")],
        ["Multicast",        "✅" if pdb.get("info_multicast") else ("❌" if pdb else "N/A")],
        ["IPv6",             "✅" if pdb.get("info_ipv6")      else ("❌" if pdb else "N/A")],
        ["Política de peer", pdb.get("policy_general") or "N/A"],
        ["Fonte PeeringDB",  "✅" if pdb else "❌ (não cadastrado)"],
    ]
    print(tabulate(rows, tablefmt="fancy_grid", numalign="left", stralign="left"))
    return ripe, pdb


def show_prefixes(asn_num):
    print(f"\n{'─'*64}")
    print(f"  AS{asn_num} — Prefixos  (RPKI: ✅ Válido | ❌ Inválido/Sem ROA)")
    print(f"{'─'*64}")

    entries = _ripe_prefixes(asn_num)
    if not entries:
        print("  Nenhum prefixo encontrado.")
        return

    def rpki_icon(status):
        if status == "valid":   return "✅"
        if status == "invalid": return "❌"
        return "❓"   # unknown / sem dado

    ipv4 = [e for e in entries if not e["is_v6"]]
    ipv6 = [e for e in entries if e["is_v6"]]

    if ipv4:
        rows = [[rpki_icon(e["rpki"]), e["prefix"]] for e in ipv4]
        print(tabulate(rows, headers=["RPKI", "Prefixo IPv4"],
                       tablefmt="fancy_grid", numalign="left", stralign="left"))

    if ipv6:
        rows = [[rpki_icon(e["rpki"]), e["prefix"]] for e in ipv6]
        print(tabulate(rows, headers=["RPKI", "Prefixo IPv6"],
                       tablefmt="fancy_grid", numalign="left", stralign="left"))

    total = len(entries)
    valid = sum(1 for e in entries if e["rpki"] == "valid")
    inval = sum(1 for e in entries if e["rpki"] == "invalid")
    print(f"  Resumo: {total} prefixo(s) — {valid} RPKI válido(s), {inval} inválido(s)")



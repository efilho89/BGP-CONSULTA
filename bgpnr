#!/usr/bin/env python3
"""
bgpnr - BGP Network Research Tool v2.1
Autor: Rudimar Remontti + Claude AI

Fontes: RIPE Stat + PeeringDB

Requisitos:
    apt install python3-requests python3-tabulate
    # ou: pip3 install requests tabulate

Instalação:
    wget https://raw.githubusercontent.com/efilho89/BGP-CONSULTA/main/bgpnr -O /usr/local/bin/bgpnr
    chmod +x /usr/local/bin/bgpnr

    upstreams, _ = _ripe_neighbours(asn_num)
    if not upstreams:
        print("  Nenhum upstream encontrado.")
        return

    net_map = _pdb_enrich_asns([u["asn"] for u in upstreams])
    rows = [
        {
            "ASN":        u.get("asn"),
            "Nome":       net_map.get(u.get("asn"), {}).get("name", "N/A"),
            "IPv4 paths": u.get("v4_peers", 0),
            "IPv6 paths": u.get("v6_peers", 0),
            "Power":      u.get("power", 0),
        }
        for u in upstreams
    ]
    print(tabulate(rows, headers="keys",
                   tablefmt="fancy_grid", numalign="left", stralign="left"))


